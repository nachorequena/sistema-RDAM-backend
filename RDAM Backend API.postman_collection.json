    {
      "name": "📋 Solicitudes (ciudadano)",
      "item": [
        {
          "name": "4a. Crear solicitud",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('nro_tramite con formato RDAM-YYYYMMDD-NNNN', () => {",
                  "  pm.expect(json.data.nroTramite).to.match(/^RDAM-\\d{8}-\\d{4}$/);",
                  "});",
                  "pm.test('fec_vencimiento_pago calculada al crear', () => {",
                  "  pm.expect(json.data.fecVencimientoPago).to.be.a('string');",
                  "  const fecVenc = new Date(json.data.fecVencimientoPago);",
                  "  const createdAt = new Date(json.data.createdAt);",
                  "  const diffDias = Math.round((fecVenc - createdAt) / (1000*60*60*24));",
                  "  pm.expect(diffDias).to.be.within(14, 16);",
                  "  console.log('Días hasta vencimiento pago:', diffDias);",
                  "});",
                  "pm.collectionVariables.set('NRO_TRAMITE', json.data.nroTramite);",
                  "pm.environment.set('NRO_TRAMITE', json.data.nroTramite);",
                  "pm.collectionVariables.set('SOLICITUD_ID', json.data.id);",
                  "pm.environment.set('SOLICITUD_ID', json.data.id);",
                  "console.log('Trámite creado:', json.data.nroTramite);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const adjuntoId = pm.environment.get('ADJUNTO_ID') || pm.collectionVariables.get('ADJUNTO_ID');",
                  "if (!adjuntoId) {",
                  "    throw new Error('⚠️ ADJUNTO_ID no está definido. Primero ejecutá \"3a. Subir adjunto (PDF)\" para obtener un adjunto_id válido.');",
                  "}",
                  "pm.variables.set('ADJUNTO_ID', adjuntoId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{CITIZEN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cuil\": \"20-34567890-1\",\n  \"nombreCompleto\": \"Juan Carlos Pérez\",\n  \"email\": \"juan@test.com\",\n  \"telefono\": \"+54911234567\",\n  \"tipoCertId\": 1,\n  \"adjuntoIds\": [{{ADJUNTO_ID}}]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
