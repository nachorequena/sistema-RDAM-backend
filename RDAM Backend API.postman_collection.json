        {
          "name": "4e. Iniciar pago — genera payload para PlusPagos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Payload encriptado contiene campos PlusPagos', () => {",
                  "  pm.expect(json.data.Comercio).to.be.a('string');",
                  "  pm.expect(json.data.TransaccionComercioId).to.match(",
                  "    /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i,",
                  "    'TransaccionComercioId debe ser un UUID v4'",
                  "  );",
                  "  pm.expect(json.data.Monto).to.be.a('string');",
                  "  pm.expect(json.data.CallbackSuccess).to.be.a('string');",
                  "  pm.expect(json.data.UrlSuccess).to.be.a('string');",
                  "  pm.expect(json.data.pluspagosUrl).to.be.a('string');",
                  "});",
                  "pm.environment.set('PAGO_INTENTO_ID', json.data.TransaccionComercioId);",
                  "pm.collectionVariables.set('PAGO_INTENTO_ID', json.data.TransaccionComercioId);",
                  "console.log('UUID del intento guardado:', json.data.TransaccionComercioId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{CITIZEN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/solicitudes/{{NRO_TRAMITE}}/iniciar-pago",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "solicitudes",
                "{{NRO_TRAMITE}}",
                "iniciar-pago"
              ]
            }
